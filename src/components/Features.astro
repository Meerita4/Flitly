---
const features = [
  {
    icon: "🔍",
    title: "Busca fácilmente",
    description: "Encuentra el equipo perfecto cerca de ti con filtros por tipo, precio y disponibilidad."
  },
  {
    icon: "📱",
    title: "Reserva instantánea",
    description: "Reserva en segundos desde tu móvil. Sin llamadas, sin esperas. Todo digital."
  },
  {
    icon: "🛡️",
    title: "100% Seguro",
    description: "Todos los alquileres están protegidos. Seguro incluido para ti y tu equipo."
  },
  {
    icon: "💬",
    title: "Chat directo",
    description: "Comunícate directamente con el propietario para resolver cualquier duda."
  },
  {
    icon: "⭐",
    title: "Reseñas verificadas",
    description: "Lee opiniones reales de otros usuarios antes de reservar."
  },
  {
    icon: "💰",
    title: "Gana dinero",
    description: "¿Tienes equipo sin usar? Ponlo a trabajar y genera ingresos extra cada mes."
  }
];
---

<section class="features" id="features">
  <div class="container">
    <h2 class="section-title">¿Por qué Flitly?</h2>
    <p class="section-subtitle">
      Todo lo que necesitas para disfrutar del deporte sin complicaciones
    </p>

    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card">
          <div class="feature-icon">{feature.icon}</div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 6rem 0;
    background: linear-gradient(180deg, var(--dark) 0%, var(--dark-light) 50%, var(--dark) 100%);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    padding: 2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1.5rem;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(14, 165, 233, 0.3);
    transform: translateY(-5px);
  }

  .feature-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    background: var(--gradient);
    border-radius: 1rem;
    margin-bottom: 1.25rem;
  }

  .feature-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .feature-description {
    color: var(--gray-light);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  @media (max-width: 968px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
