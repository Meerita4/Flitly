---
const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: "Busca fácilmente",
    description: "Encuentra el equipo perfecto cerca de ti con filtros avanzados por tipo, precio, disponibilidad y ubicación."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" rx="2" width="14" height="20"/><path d="M12 18h.01"/></svg>`,
    title: "Reserva instantánea",
    description: "Reserva en segundos desde cualquier dispositivo. Sin llamadas, sin esperas. Todo 100% digital."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: "100% Seguro",
    description: "Todos los alquileres están protegidos con seguro incluido. Pagos seguros y verificados."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Chat integrado",
    description: "Comunícate directamente con el propietario para resolver cualquier duda antes de reservar."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: "Reseñas verificadas",
    description: "Lee opiniones reales de otros usuarios y toma decisiones informadas antes de cada reserva."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: "Genera ingresos",
    description: "¿Tienes equipo sin usar? Ponlo a trabajar y genera ingresos extra cada mes de forma segura."
  }
];

const stats = [
  { value: "+50", label: "Tipos de equipo" },
  { value: "100%", label: "Alquiler seguro" },
  { value: "24/7", label: "Atención inmediata" }
];
---

<section class="features" id="features">
  <!-- Background decoration -->
  <div class="features-bg">
    <div class="features-gradient"></div>
  </div>

  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      <span class="section-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        <span data-i18n="feat.badge">Características</span>
      </span>
      <h2 class="section-title"><span data-i18n="feat.title1">Todo lo que necesitas</span><br/><span class="gradient-text" data-i18n="feat.title2">en una sola app</span></h2>
      <p class="section-subtitle" data-i18n="feat.subtitle">
        Diseñamos Flitly pensando en ti. Una experiencia simple, segura y completa para disfrutar del deporte sin complicaciones.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="features-grid">
      {features.map((feature, index) => (
        <div class="feature-card" style={`--delay: ${index * 0.1}s`}>
          <div class="feature-icon" set:html={feature.icon} />
          <h3 class="feature-title" data-i18n={`feat.${index}.title`}>{feature.title}</h3>
          <p class="feature-description" data-i18n={`feat.${index}.desc`}>{feature.description}</p>
        </div>
      ))}
    </div>

    <!-- Stats Section -->
    <div class="stats-section">
      <div class="stats-grid">
        {stats.map((stat, index) => (
          <div class="stat-item">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label" data-i18n={`stat.${index}.label`}>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .features {
    padding: 8rem 0;
    position: relative;
    overflow: hidden;
  }

  .features-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .features-gradient {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.08) 0%, transparent 70%);
    filter: blur(60px);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: var(--radius-full);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--primary-lighter);
    margin-bottom: 1.25rem;
  }

  .section-badge svg {
    width: 16px;
    height: 16px;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.25rem;
    color: var(--light);
  }

  .gradient-text {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--gray-light);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 5rem;
  }

  .feature-card {
    padding: 2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-xl);
    transition: all 0.3s ease;
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: var(--delay);
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .feature-card:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(37, 99, 235, 0.3);
    transform: translateY(-4px);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient);
    border-radius: var(--radius-lg);
    margin-bottom: 1.25rem;
    color: white;
  }

  .feature-icon :global(svg) {
    width: 24px;
    height: 24px;
  }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--light);
  }

  .feature-description {
    color: var(--gray-light);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin: 0;
  }

  /* Stats Section */
  .stats-section {
    padding: 3rem;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(6, 182, 212, 0.05) 100%);
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: var(--radius-2xl);
  }

  .stats-grid {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .stat-item {
    text-align: center;
    min-width: 120px;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-xl);
    background: rgba(255,255,255,0.03);
    box-shadow: 0 2px 8px 0 rgba(37,99,235,0.04);
    transition: background 0.2s;
  }
  .stat-item:hover {
    background: rgba(37,99,235,0.08);
  }

  .stat-value {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--gray-light);
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .stats-grid {
      gap: 1.5rem;
    }
    .section-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .features {
      padding: 5rem 0;
    }
    .features-grid {
      grid-template-columns: 1fr;
    }
    .stats-grid {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }
    .stats-section {
      padding: 2rem 1.5rem;
    }
    .stat-value {
      font-size: 2rem;
    }
    .section-title {
      font-size: 2rem;
    }
  }
</style>
