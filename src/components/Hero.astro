---
import { Image } from 'astro:assets';
import logoSrc from '../images/logo_flitly.png';
import inicioImg from '../images/inicio.jpg';

const categoriesES = [
  "Kayaks",
  "Tablas de Surf", 
  "Bicicletas",
  "Paddle Surf",
  "Equipos de Buceo",
  "Esquís"
];

const categoriesEN = [
  "Kayaks",
  "Surfboards",
  "Bicycles",
  "Paddleboards",
  "Diving Gear",
  "Skis"
];

const trustBadges = [
  { icon: "✓", text: "Sin comisión oculta" },
  { icon: "✓", text: "Seguro incluido" },
  { icon: "✓", text: "Soporte 24/7" }
];
---

<section class="hero" id="hero">
  <!-- Background Effects -->
  <div class="hero-bg">
    <div class="hero-gradient-orb hero-gradient-orb-1"></div>
    <div class="hero-gradient-orb hero-gradient-orb-2"></div>
    <div class="hero-grid"></div>
  </div>
  
  <div class="container">
    <div class="hero-content">
      <!-- Badge -->
      <div class="hero-badge">
        <span class="badge-pulse"></span>
        <span data-i18n="hero.badge">Lanzamiento Año 2026</span>
      </div>

      <!-- Main Title -->
      <h1 class="hero-title">
        <span data-i18n="hero.verb">Alquila</span>
        <span class="title-carousel" id="title-carousel">
          <span class="carousel-word active">Kayaks</span>
        </span>
        <br />
        <span class="title-highlight" data-i18n="hero.highlight">en cualquier lugar</span>
      </h1>

      <p class="hero-description" data-i18n="hero.description">
        La plataforma que conecta deportistas con propietarios de equipos acuáticos 
        y deportivos. Reserva en segundos, disfruta durante horas.
      </p>
      
      <!-- Trust Badges -->
      <div class="trust-badges">
        {trustBadges.map((badge, i) => (
          <div class="trust-badge">
            <span class="trust-icon">{badge.icon}</span>
            <span data-i18n={`trust.${i}`}>{badge.text}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Visual Section -->
    <div class="hero-visual">
      <div class="phone-container">
        <div class="phone-mockup">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <Image src={inicioImg} alt="Flitly App - Pantalla de inicio" class="phone-screen-img" loading="eager" />
          </div>
        </div>
        
        <!-- Floating elements -->
        <div class="floating-card floating-card-1">
          <div class="floating-icon">🏆</div>
          <div class="floating-text">
            <span class="floating-title" data-i18n="float.1.title">Top Rated</span>
            <span class="floating-subtitle" data-i18n="float.1.sub">Usuario verificado</span>
          </div>
        </div>
        
        <div class="floating-card floating-card-2">
          <div class="floating-icon">🔒</div>
          <div class="floating-text">
            <span class="floating-title" data-i18n="float.2.title">100% Seguro</span>
            <span class="floating-subtitle" data-i18n="float.2.sub">Pagos protegidos</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ categoriesES, categoriesEN }}>
  // Title carousel
  const carouselEl = document.getElementById('title-carousel');
  if (carouselEl) {
    let currentCategories = localStorage.getItem('flitly-lang') === 'en' ? categoriesEN : categoriesES;
    let currentIndex = 0;

    // Update categories when language changes
    window.addEventListener('langchange', (e) => {
      currentCategories = e.detail.categories;
      currentIndex = 0;
      const currentWord = carouselEl.querySelector('.carousel-word');
      if (currentWord) currentWord.textContent = currentCategories[0];
    });
    
    setInterval(() => {
      currentIndex = (currentIndex + 1) % currentCategories.length;
      const currentWord = carouselEl.querySelector('.carousel-word');
      if (currentWord) {
        currentWord.classList.remove('active');
        currentWord.classList.add('exit');
        
        setTimeout(() => {
          currentWord.textContent = currentCategories[currentIndex];
          currentWord.classList.remove('exit');
          currentWord.classList.add('active');
        }, 300);
      }
    }, 2500);
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 0 4rem;
    overflow: hidden;
  }

  /* Background Effects */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .hero-gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
  }

  .hero-gradient-orb-1 {
    top: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.4) 0%, transparent 70%);
  }

  .hero-gradient-orb-2 {
    bottom: -30%;
    left: -15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.3) 0%, transparent 70%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(37, 99, 235, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37, 99, 235, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content {
    max-width: 600px;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 1rem;
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: var(--radius-full);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--primary-lighter);
    margin-bottom: 1.5rem;
  }

  .badge-pulse {
    width: 8px;
    height: 8px;
    background: var(--primary);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { 
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.4);
    }
    50% { 
      opacity: 0.8;
      box-shadow: 0 0 0 8px rgba(37, 99, 235, 0);
    }
  }

  /* Title */
  .hero-title {
    font-size: 3.75rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .title-carousel {
    display: inline-block;
    position: relative;
    min-width: 280px;
    text-align: left;
  }

  .carousel-word {
    display: inline-block;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: all 0.3s ease;
  }

  .carousel-word.exit {
    opacity: 0;
    transform: translateY(-10px);
  }

  .carousel-word.active {
    opacity: 1;
    transform: translateY(0);
  }

  .title-highlight {
    color: var(--gray-lighter);
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--gray-light);
    margin-bottom: 2rem;
    line-height: 1.75;
    max-width: 520px;
  }

  /* Trust Badges */
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--gray-light);
  }

  .trust-icon {
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
    border-radius: 50%;
    font-size: 0.625rem;
    font-weight: 700;
  }

  /* Hero Visual */
  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .phone-container {
    position: relative;
  }

  .phone-mockup {
    width: 300px;
    height: 620px;
    background: linear-gradient(145deg, #1a1f2e 0%, #0f1419 100%);
    border-radius: 3rem;
    padding: 0.625rem;
    box-shadow: 
      0 25px 50px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    position: relative;
  }

  .phone-notch {
    position: absolute;
    top: 0.625rem;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 28px;
    background: #0a0e1a;
    border-radius: 0 0 1rem 1rem;
    z-index: 10;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    background: var(--dark);
    border-radius: 2.5rem;
    overflow: hidden;
  }

  .phone-screen-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 2.5rem;
  }

  /* Floating Cards */
  .floating-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(26, 31, 46, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    animation: float 6s ease-in-out infinite;
  }

  .floating-card-1 {
    top: 15%;
    right: -20px;
    animation-delay: 0s;
  }

  .floating-card-2 {
    bottom: 20%;
    left: -30px;
    animation-delay: 3s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .floating-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient);
    border-radius: var(--radius);
    font-size: 1rem;
  }

  .floating-text {
    display: flex;
    flex-direction: column;
  }

  .floating-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--light);
  }

  .floating-subtitle {
    font-size: 0.6875rem;
    color: var(--gray);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero .container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-content {
      max-width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-title {
      font-size: 3rem;
    }

    .title-carousel {
      text-align: center;
    }

    .hero-description {
      max-width: 500px;
    }

    .trust-badges {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .floating-card-1 {
      right: 0;
    }

    .floating-card-2 {
      left: 0;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 6rem 0 3rem;
    }

    .hero-title {
      font-size: 2.25rem;
    }

    .title-carousel {
      min-width: 180px;
    }

    .phone-mockup {
      width: 260px;
      height: 540px;
    }

    .floating-card {
      display: none;
    }

    .trust-badges {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
